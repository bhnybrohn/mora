# Copy to .env and edit for local dev.

# ─── Database ──────────────────────────────────────────────────────────────
# Default: Postgres in the docker-compose stack (recommended).
# Note the non-standard port (5434) — see docker-compose.yml for why.
DATABASE_URL=postgresql+asyncpg://mora:mora@localhost:5434/mora
# Alternative: SQLite (no Docker required, but limited):
# DATABASE_URL=sqlite+aiosqlite:///./mora.db

# ─── Redis (for Celery / rate limiting later) ──────────────────────────────
REDIS_URL=redis://localhost:6381/0

# ─── Auth / JWT ────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
JWT_EXPIRE_MINUTES=1440

# ─── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","capacitor://localhost"]

# ─── Storage ───────────────────────────────────────────────────────────────
# In dev we default to a local-filesystem backend so the upload pipeline
# works without R2 credentials. Files land in ./uploads/ and are served by
# the /dev-uploads/{key} endpoint.
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=./uploads
STORAGE_PUBLIC_BASE_URL=http://localhost:8000

# Set STORAGE_BACKEND=r2 and fill these in to use Cloudflare R2.
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_PHOTOS=mora-photos-dev
R2_BUCKET_PREVIEWS=mora-previews-dev

# ─── SMS (OTP delivery — leave blank for the dev logger) ───────────────────
SMS_PROVIDER=dev
TERMII_API_KEY=
TERMII_SENDER_ID=Mora
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ─── Payments (stubbed until provider accounts exist) ──────────────────────
PAYSTACK_SECRET_KEY=
FLUTTERWAVE_SECRET_KEY=
STRIPE_SECRET_KEY=

# ─── Web push ──────────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=hello@mora.app
